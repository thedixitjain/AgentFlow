# Server
PORT=4000
NODE_ENV=development
DATA_DIR=./data

# Primary LLM - Groq (recommended)
GROQ_API_KEY=your_groq_api_key

# Optional fallbacks
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key

# Cost Management
DAILY_BUDGET=10

# CORS: comma-separated frontend origins (no trailing slashes)
# Production example: https://agentflow.thedixitjain.com,http://localhost:3000
CORS_ORIGIN=http://localhost:3000
