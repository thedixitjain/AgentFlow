# Backend (production on Vercel avoids CORS; see README)
# NEXT_PUBLIC_API_URL=/agentflow-api
# BACKEND_URL=https://your-service.onrender.com
#
# Local dev (Next + Express on same machine):
# NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Google auth
# NEXT_PUBLIC_AUTH_ENABLED=true
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=replace_with_a_long_random_string
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Primary provider for the Next.js chat route
GROQ_API_KEY=your_groq_api_key_here

# Optional: YouTube embed URL for the landing page demo (see docs/DEMO_VIDEO.md)
# NEXT_PUBLIC_DEMO_VIDEO_URL=https://www.youtube.com/embed/YOUR_VIDEO_ID

# Optional fallback for the Next.js chat route
GEMINI_API_KEY=your_gemini_api_key_here
